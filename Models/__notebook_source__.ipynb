# Generate Streamlit app template with Objective I emphasis
app_code = '''
import streamlit as st
import torch
import numpy as np
import pandas as pd
import joblib
import json
import time
import os

st.set_page_config(page_title="Encrypted Traffic Anomaly Detector", layout="wide")
st.title("Real-Time Anomaly Detection on Encrypted Networks")
st.markdown("### Research Implementation: Optimized Interpretability & Relational Modeling")

# Load model and configuration
@st.cache_resource
def load_model():
    import torch.nn as nn
    
    # Model architecture definitions (same as training)
    class FastAttributionExplainer(nn.Module):
        def __init__(self, input_dim):
            super().__init__()
            self.net = nn.Sequential(
                nn.Linear(input_dim, 128), nn.BatchNorm1d(128), nn.ReLU(), nn.Dropout(0.2),
                nn.Linear(128, 64), nn.BatchNorm1d(64), nn.ReLU(), nn.Linear(64, input_dim)
            )
        def forward(self, x):
            return self.net(x)
    
    class RelationalModelingLayer(nn.Module):
        def __init__(self, input_dim, output_dim):
            super().__init__()
            self.relation_net = nn.Sequential(
                nn.Linear(input_dim, output_dim * 4), nn.BatchNorm1d(output_dim * 4), nn.ReLU(), nn.Dropout(0.3),
                nn.Linear(output_dim * 4, output_dim * 2), nn.BatchNorm1d(output_dim * 2), nn.ReLU(),
                nn.Linear(output_dim * 2, output_dim)
            )
            self.residual = nn.Linear(input_dim, output_dim) if input_dim != output_dim else nn.Identity()
        def forward(self, x):
            relational = self.relation_net(x)
            residual = self.residual(x)
            return nn.functional.relu(relational + residual)
    
    class ProposedAnomalyDetector(nn.Module):
        def __init__(self, tabular_dim, relational_dim=64):
            super().__init__()
            self.tabular_net = nn.Sequential(
                nn.Linear(tabular_dim, 128), nn.BatchNorm1d(128), nn.ReLU(), nn.Dropout(0.3),
                nn.Linear(128, 64), nn.BatchNorm1d(64), nn.ReLU()
            )
            self.relational_layer = RelationalModelingLayer(input_dim=tabular_dim, output_dim=relational_dim)
            self.classifier = nn.Sequential(
                nn.Linear(64 + relational_dim, 64), nn.BatchNorm1d(64), nn.ReLU(), nn.Dropout(0.3),
                nn.Linear(64, 32), nn.ReLU(), nn.Linear(32, 1)
            )
            self.explainer = FastAttributionExplainer(tabular_dim)
        def forward(self, x):
            tabular_feat = self.tabular_net(x)
            relational_feat = self.relational_layer(x)
            combined = torch.cat([tabular_feat, relational_feat], dim=1)
            logits = self.classifier(combined).squeeze(-1)
            importances = self.explainer(x)
            return logits, importances
    
    # Load configuration
    with open('deployment_artifacts/model_config.json') as f:
        config = json.load(f)
    
    # Initialize and load model
    model = ProposedAnomalyDetector(tabular_dim=config['tabular_dim'])
    model.load_state_dict(torch.load('deployment_artifacts/model_weights.pt', map_location='cpu'))
    model.eval()
    
    # Load preprocessing
    scaler = joblib.load('deployment_artifacts/scaler.pkl')
    le = joblib.load('deployment_artifacts/label_encoder.pkl')
    
    return model, scaler, le, config

try:
    model, scaler, le, config = load_model()
    st.success("✓ Model loaded successfully")
except Exception as e:
    st.error(f"✗ Error loading model: {e}")
    st.stop()

# Sidebar: Upload and configuration
st.sidebar.header("Upload Network Traffic Data")
uploaded_file = st.sidebar.file_uploader("Choose a CSV file with network flow features", type=["csv"])

# Display Objective I status prominently
st.sidebar.markdown("---")
st.sidebar.subheader("🎯 Objective I: Real-Time Interpretability")
st.sidebar.metric("Target Latency", "< 300 ms")
st.sidebar.metric("Achieved Latency", f"{config['latency_achieved_ms']:.2f} ms",
                  delta="✓ PASSED" if config['latency_target_met'] else "✗ PENDING")
st.sidebar.metric("Throughput", f"{config['throughput_flows_per_sec']:.0f} flows/sec")

if uploaded_file is not None:
    with st.spinner("Processing network flows..."):
        try:
            # Load and preprocess data
            df = pd.read_csv(uploaded_file)
            st.write(f"✓ Loaded {len(df)} network flows")
            
            # Feature selection and scaling
            with open('deployment_artifacts/feature_names.json') as f:
                features = json.load(f)
            
            available = [c for c in features if c in df.columns]
            if len(available) < len(features) * 0.8:
                st.warning(f"⚠ Only {len(available)}/{len(features)} expected features found")
            
            X = df[available].values.astype(float)
            X = scaler.transform(X)
            X_t = torch.tensor(X, dtype=torch.float32)
            
            # OBJECTIVE I: Measure inference latency
            start = time.perf_counter()
            with torch.no_grad():
                logits, importance = model(X_t)
            inference_time = (time.perf_counter() - start) * 1000 / len(X)
            
            # Get predictions and probabilities
            probs = torch.sigmoid(logits).numpy()
            thresh = config['optimal_thresholds'].get('default', 0.5)
            preds = (probs > thresh).astype(int)
            
            # Display key metrics with Objective I emphasis
            col1, col2, col3, col4 = st.columns(4)
            col1.metric("Avg Inference Latency", f"{inference_time:.2f} ms",
                       delta="✓ Real-time" if inference_time < 300 else "⚠ Optimize")
            col2.metric("Anomalies Detected", f"{preds.sum()} / {len(preds)}",
                       delta=f"{preds.mean()*100:.1f}% anomaly rate")
            col3.metric("Model Confidence", f"{probs.mean():.3f}",
                       delta="High" if probs.mean() > 0.7 else "Review")
            col4.metric("Throughput", f"{1000/inference_time:.0f} flows/sec")
            
            # Main content tabs
            tab1, tab2, tab3, tab4 = st.tabs(["📊 Predictions", "🔍 Feature Importance", "📈 Analytics", "⚙️ Raw Data"])
            
            with tab1:
                st.subheader("Anomaly Detection Results")
                
                # Prediction distribution
                pred_counts = pd.Series(preds).value_counts().rename(index={0: 'Benign', 1: 'Anomaly'})
                st.bar_chart(pred_counts)
                
                # Sample predictions table
                sample_df = pd.DataFrame({
                    'Flow_ID': range(min(20, len(preds))),
                    'Prediction': ['🔴 Anomaly' if p else '🟢 Benign' for p in preds[:20]],
                    'Confidence': [f"{p*100:.1f}%" for p in probs[:20]],
                    'Risk_Level': ['High' if p > 0.8 else 'Medium' if p > 0.5 else 'Low' for p in probs[:20]]
                })
                st.dataframe(sample_df, use_container_width=True)
                
                # Alert for high-risk flows
                high_risk = np.where((preds == 1) & (probs > 0.8))[0]
                if len(high_risk) > 0:
                    st.warning(f"⚠ {len(high_risk)} high-risk anomalies detected (confidence >80%)")
            
            with tab2:
                st.subheader("Interpretability: Feature Contributions")
                st.markdown("*FastAttributionExplainer provides real-time feature attribution*")
                
                # Calculate feature importance
                feat_imp = importance.abs().mean(0).numpy()
                imp_df = pd.DataFrame({
                    'Feature': features[:len(feat_imp)],
