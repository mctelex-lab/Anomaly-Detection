print("\n[BENCHMARK] Training XGBoost + SHAP with Class Weighting")

class DummyXGBModel:
    """Fallback model when XGBoost cannot train due to single-class data"""
    def __init__(self, majority_class, feature_names):
        self.majority_class = majority_class
        self.feature_names = feature_names
        self.classes_ = np.array([0, 1]) if majority_class in [0, 1] else np.array([majority_class])
        
    def predict(self, X):
        return np.full(len(X), self.majority_class)
    
    def predict_proba(self, X):
        if len(self.classes_) == 2:
            prob = np.zeros((len(X), 2))
            prob[:, self.majority_class] = 1.0
            return prob
        else:
            return np.ones((len(X), 1))
    
    def get_booster(self):
        return None  # For SHAP compatibility check

def train_benchmark_xgb_robust(X_train, y_train, X_val, y_val, anomaly_ratio, device):
    """
    Ultra-robust XGBoost training that handles ANY class distribution issue.
    CRITICAL FIX: Checks TRAINING set classes (not validation) and provides safe fallback.
    """
    scale_pos_weight = (1 - anomaly_ratio) / (anomaly_ratio + 1e-6)
    
    # CRITICAL: Check TRAINING set has both classes
    unique_train = np.unique(y_train)
    has_both_train_classes = len(unique_train) == 2 and set(unique_train) == {0, 1}
    
    if not has_both_train_classes:
        print(f"  [WARN] Training set has only class {unique_train}. Using dummy fallback model.")
        majority_class = int(np.bincount(y_train.astype(int)).argmax())
        return DummyXGBModel(majority_class, feat_dark if 'feat_dark' in globals() else None)
    
    # Check validation set for eval_set usage
    unique_val = np.unique(y_val)
    has_both_val_classes = len(unique_val) == 2 and set(unique_val) == {0, 1}
    
    try:
        xgb_model = xgb.XGBClassifier(
            objective='binary:logistic',
            eval_metric='logloss',
            max_depth=8,
            n_estimators=300,
            learning_rate=0.03,
            subsample=0.8,
            colsample_bytree=0.8,
            scale_pos_weight=scale_pos_weight,
            tree_method='hist',
            random_state=42,
            use_label_encoder=False
        )
        
        if has_both_val_classes:
            print(f"  Training with eval_set for early stopping")
            xgb_model.fit(X_train, y_train, eval_set=[(X_val, y_val)], verbose=False)
        else:
            print(f"  Training without eval_set (validation has single class)")
            xgb_model.fit(X_train, y_train, verbose=False)
        
        return xgb_model
        
    except Exception as e:
        print(f"  [ERROR] XGBoost training failed: {e}. Using dummy fallback.")
        majority_class = int(np.bincount(y_train.astype(int)).argmax())
        return DummyXGBModel(majority_class, feat_dark if 'feat_dark' in globals() else None)

