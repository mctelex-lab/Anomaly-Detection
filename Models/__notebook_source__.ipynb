def evaluate_model_comprehensive(model, X_test, y_test, device, dataset_name):
    model.eval()
    model = model.to(device)  # Ensure model is on correct device
    X_t = torch.tensor(X_test, dtype=torch.float32)
    
    # Latency measurement (CPU-safe timing)
    latencies = []
    for _ in range(5):
        start = time.perf_counter()
        with torch.no_grad():
            X_t_device = X_t.to(device)
            logits, importances = model(X_t_device)
            importances = importances.cpu()  # Move to CPU for processing
        latency_total = time.perf_counter() - start
        latencies.append((latency_total / len(X_test)) * 1000)
    
    probs = torch.sigmoid(logits).cpu().numpy()
    
    # Find optimal threshold
    optimal_thresh = find_optimal_threshold(y_test, probs)
    preds = (probs > optimal_thresh).astype(int)
    
    # Calculate AUC-PR safely
    auc_pr_value = calculate_auc_pr(y_test, probs)
    
    # Comprehensive metrics
    metrics = {
        'Accuracy': accuracy_score(y_test, preds),
        'Precision': precision_score(y_test, preds, zero_division=0),
        'Recall': recall_score(y_test, preds, zero_division=0),
        'F1-Score': f1_score(y_test, preds, zero_division=0),
        'AUC-ROC': roc_auc_score(y_test, probs),
        'AUC-PR': auc_pr_value,
        'Latency_ms': np.mean(latencies),
        'Latency_p95': np.percentile(latencies, 95),
        'Optimal_Threshold': float(optimal_thresh),
        'Anomaly_Rate_Predicted': float(preds.mean())
    }
    
    return metrics, preds, probs, importances, optimal_thresh

