def evaluate_benchmark_comprehensive(model, X_test, y_test, dataset_name):
    y_pred = model.predict(X_test)
    y_prob = model.predict_proba(X_test)[:, 1]
    
    # Find optimal threshold for fair comparison
    optimal_thresh = find_optimal_threshold(y_test, y_prob)
    preds_opt = (y_prob > optimal_thresh).astype(int)
    
    # Latency measurement
    latencies = []
    for _ in range(5):
        start = time.perf_counter()
        _ = model.predict(X_test)
        latency = ((time.perf_counter() - start) / len(X_test)) * 1000
        latencies.append(latency)
    
    # Calculate AUC-PR safely
    auc_pr_value = calculate_auc_pr(y_test, y_prob)
    
    metrics = {
        'Accuracy': accuracy_score(y_test, preds_opt),
        'Precision': precision_score(y_test, preds_opt, zero_division=0),
        'Recall': recall_score(y_test, preds_opt, zero_division=0),
        'F1-Score': f1_score(y_test, preds_opt, zero_division=0),
        'AUC-ROC': roc_auc_score(y_test, y_prob),
        'AUC-PR': auc_pr_value,
        'Latency_ms': np.mean(latencies),
        'Latency_p95': np.percentile(latencies, 95),
        'Optimal_Threshold': float(optimal_thresh),
        'Anomaly_Rate_Predicted': float(preds_opt.mean())
    }
    
    return metrics, preds_opt, y_prob, optimal_thresh

