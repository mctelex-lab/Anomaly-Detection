print("\n[BENCHMARK] Training XGBoost + SHAP with Class Weighting")

def train_benchmark_xgb(X_train, y_train, X_val, y_val, anomaly_ratio, device):
    scale_pos_weight = (1 - anomaly_ratio) / (anomaly_ratio + 1e-6)
    
    # Use CPU-safe tree method
    tree_method = 'gpu_hist' if (device.type == 'cuda' and torch.cuda.is_available()) else 'hist'
    
    xgb_model = xgb.XGBClassifier(
        objective='binary:logistic',
        eval_metric='auc',
        max_depth=10,
        n_estimators=500,
        learning_rate=0.03,
        subsample=0.8,
        colsample_bytree=0.8,
        scale_pos_weight=scale_pos_weight,
        tree_method=tree_method,
        random_state=42,
        use_label_encoder=False,
        early_stopping_rounds=20
    )
    
    xgb_model.fit(X_train, y_train, 
                 eval_set=[(X_val, y_val)], 
                 verbose=False)
    
    return xgb_model

# Train benchmark on both datasets
xgb_dark = train_benchmark_xgb(X_d_tr, y_d_tr, X_d_va, y_d_va, ratio_dark, device)
xgb_ids = train_benchmark_xgb(X_i_tr, y_i_tr, X_i_va, y_i_va, ratio_ids, device)

def evaluate_benchmark_comprehensive(model, X_test, y_test, dataset_name):
    y_pred = model.predict(X_test)
    y_prob = model.predict_proba(X_test)[:, 1]
    
    # Find optimal threshold for fair comparison
    optimal_thresh = find_optimal_threshold(y_test, y_prob)
    preds_opt = (y_prob > optimal_thresh).astype(int)
    
    # Latency measurement
    latencies = []
    for _ in range(5):
        start = time.perf_counter()
        _ = model.predict(X_test)
        latency = ((time.perf_counter() - start) / len(X_test)) * 1000
        latencies.append(latency)
    
    # Calculate AUC-PR safely
    auc_pr_value = calculate_auc_pr(y_test, y_prob)
    
    metrics = {
        'Accuracy': accuracy_score(y_test, preds_opt),
        'Precision': precision_score(y_test, preds_opt, zero_division=0),
        'Recall': recall_score(y_test, preds_opt, zero_division=0),
        'F1-Score': f1_score(y_test, preds_opt, zero_division=0),
        'AUC-ROC': roc_auc_score(y_test, y_prob),
        'AUC-PR': auc_pr_value,
        'Latency_ms': np.mean(latencies),
        'Latency_p95': np.percentile(latencies, 95),
        'Optimal_Threshold': float(optimal_thresh),
        'Anomaly_Rate_Predicted': float(preds_opt.mean())
    }
    
    return metrics, preds_opt, y_prob, optimal_thresh

# Evaluate benchmark
