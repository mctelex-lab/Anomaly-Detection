class FocalLoss(nn.Module):
    """Focal loss for handling class imbalance in anomaly detection"""
    def __init__(self, alpha=0.75, gamma=2.0):
        super().__init__()
        self.alpha = alpha
        self.gamma = gamma
        
    def forward(self, logits, targets):
        probs = torch.sigmoid(logits)
        ce_loss = nn.functional.binary_cross_entropy_with_logits(logits, targets, reduction='none')
        pt = probs * targets + (1 - probs) * (1 - targets)
        focal_loss = self.alpha * (1 - pt) ** self.gamma * ce_loss
        return focal_loss.mean()

class FastAttributionExplainer(nn.Module):
    """Lightweight surrogate model for sub-300ms feature attribution"""
    def __init__(self, input_dim):
        super().__init__()
        self.net = nn.Sequential(
            nn.Linear(input_dim, 128),
            nn.BatchNorm1d(128),
            nn.ReLU(),
            nn.Dropout(0.2),
            nn.Linear(128, 64),
            nn.BatchNorm1d(64),
            nn.ReLU(),
            nn.Linear(64, input_dim)
        )
    def forward(self, x):
        return self.net(x)

class RelationalModelingLayer(nn.Module):
    """Enhanced relational modeling with residual connections and batch norm"""
    def __init__(self, input_dim, output_dim):
        super().__init__()
        self.relation_net = nn.Sequential(
            nn.Linear(input_dim, output_dim * 4),
            nn.BatchNorm1d(output_dim * 4),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(output_dim * 4, output_dim * 2),
            nn.BatchNorm1d(output_dim * 2),
            nn.ReLU(),
            nn.Linear(output_dim * 2, output_dim)
        )
        self.residual = nn.Linear(input_dim, output_dim) if input_dim != output_dim else nn.Identity()
        
    def forward(self, x):
        relational = self.relation_net(x)
        residual = self.residual(x)
        return nn.functional.relu(relational + residual)

class ProposedAnomalyDetector(nn.Module):
    def __init__(self, tabular_dim, relational_dim=64):
        super().__init__()
        self.tabular_net = nn.Sequential(
            nn.Linear(tabular_dim, 128),
            nn.BatchNorm1d(128),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(128, 64),
            nn.BatchNorm1d(64),
            nn.ReLU()
        )
        
        self.relational_layer = RelationalModelingLayer(
            input_dim=tabular_dim, 
            output_dim=relational_dim
        )
        
        self.classifier = nn.Sequential(
            nn.Linear(64 + relational_dim, 64),
            nn.BatchNorm1d(64),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(64, 32),
            nn.ReLU(),
            nn.Linear(32, 1)
        )
        
        self.explainer = FastAttributionExplainer(tabular_dim)
        
    def forward(self, x):
        tabular_feat = self.tabular_net(x)
        relational_feat = self.relational_layer(x)
        combined = torch.cat([tabular_feat, relational_feat], dim=1)
        logits = self.classifier(combined).squeeze(-1)
        importances = self.explainer(x)
        return logits, importances

# =============================================================================
# 3. TRAINING PROPOSED MODEL
# =============================================================================

def train_model(model, X_train, y_train, X_val, y_val, anomaly_ratio, 
                epochs=50, batch_size=128, lr=1e-3, device='cpu'):
    
    model = model.to(device)
    criterion = FocalLoss(alpha=0.75, gamma=2.0)
    optimizer = optim.Adam(model.parameters(), lr=lr, weight_decay=1e-4)
    scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode='max', factor=0.5, patience=5)
    
    # Weighted sampler for balanced batches
    sample_weights = torch.tensor([1.0 if y == 0 else 5.0 for y in y_train], device='cpu')
    sampler = WeightedRandomSampler(sample_weights, len(sample_weights), replacement=True)
    
    X_tr_t = torch.tensor(X_train, dtype=torch.float32)
    y_tr_t = torch.tensor(y_train, dtype=torch.float32)
    loader = DataLoader(TensorDataset(X_tr_t, y_tr_t), batch_size=batch_size, 
                       sampler=sampler, num_workers=0)
    
    X_va_t = torch.tensor(X_val, dtype=torch.float32)
    
    best_f1 = 0
    best_model_state = None
    training_history = {'train_loss': [], 'val_f1': [], 'val_auc': []}
    
    for epoch in range(epochs):
        model.train()
        total_loss = 0
        
        for xb, yb in loader:
            xb, yb = xb.to(device), yb.to(device)
            optimizer.zero_grad()
            logits, _ = model(xb)
            loss = criterion(logits, yb)
            loss.backward()
            optimizer.step()
            total_loss += loss.item()
        
        model.eval()
        with torch.no_grad():
            X_va_device = X_va_t.to(device)
            val_logits, _ = model(X_va_device)
            val_probs = torch.sigmoid(val_logits).cpu().numpy()
        
        val_f1 = f1_score(y_val, (val_probs > 0.5).astype(int), zero_division=0)
        val_auc = roc_auc_score(y_val, val_probs)
        
        training_history['train_loss'].append(total_loss / len(loader))
        training_history['val_f1'].append(val_f1)
        training_history['val_auc'].append(val_auc)
        
        scheduler.step(val_f1)
        
        if val_f1 > best_f1:
            best_f1 = val_f1
            best_model_state = {k: v.cpu().clone() for k, v in model.state_dict().items()}
        
        if (epoch + 1) % 10 == 0:
            print(f"  Epoch {epoch+1}/{epochs}, Loss: {total_loss/len(loader):.4f}, Val F1: {val_f1:.4f}, Val AUC: {val_auc:.4f}")
    
    if best_model_state is not None:
        model.load_state_dict(best_model_state)
    
    return model, training_history

