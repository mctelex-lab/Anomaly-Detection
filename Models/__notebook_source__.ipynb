# =============================================================================
# 2. PROPOSED MODEL (Relational + Fast Attribution)
# =============================================================================
class FastAttributionExplainer(nn.Module):
    def __init__(self, input_dim):
        super().__init__()
        self.net = nn.Sequential(
            nn.Linear(input_dim, 128), nn.ReLU(), nn.Dropout(0.2),
            nn.Linear(128, 64), nn.ReLU(), nn.Linear(64, input_dim)
        )
    def forward(self, x):
        return self.net(x)

class RelationalModelingLayer(nn.Module):
    def __init__(self, input_dim, output_dim=32):
        super().__init__()
        self.relation_net = nn.Sequential(
            nn.Linear(input_dim, output_dim * 2), nn.ReLU(),
            nn.Linear(output_dim * 2, output_dim), nn.ReLU()
        )
    def forward(self, x):
        return self.relation_net(x)

class ProposedAnomalyDetector(nn.Module):
    def __init__(self, tabular_dim, relational_dim=32):
        super().__init__()
        self.tabular_net = nn.Sequential(
            nn.Linear(tabular_dim, 64), nn.ReLU(), nn.Linear(64, 32), nn.ReLU()
        )
        self.relational_layer = RelationalModelingLayer(tabular_dim, relational_dim)
        self.classifier = nn.Sequential(
            nn.Linear(32 + relational_dim, 32), nn.ReLU(), nn.Linear(32, 1)
        )
        self.explainer = FastAttributionExplainer(tabular_dim)
    
    def forward(self, x):
        tabular_feat = self.tabular_net(x)
        relational_feat = self.relational_layer(x)
        combined = torch.cat([tabular_feat, relational_feat], dim=1)
        logits = self.classifier(combined).squeeze(-1)
        importances = self.explainer(x)
        return logits, importances

# Initialize model
model = ProposedAnomalyDetector(tabular_dim=X_d_tr.shape[1]).to(device)

# Stronger imbalance handling
anomaly_ratio = y_d_tr.mean()
pos_weight = torch.tensor([(1 - anomaly_ratio) / (anomaly_ratio + 1e-6) * 8]).to(device)  # Strong weight on anomalies
optimizer = optim.Adam(model.parameters(), lr=1e-3, weight_decay=1e-4)
criterion = nn.BCEWithLogitsLoss(pos_weight=pos_weight)

# Training with validation
print("\n[TRAINING] Proposed Model (Relational + Fast Attribution + Imbalance Handling)")
batch_size = 256
epochs = 20

X_tr_t = torch.tensor(X_d_tr, dtype=torch.float32).to(device)
y_tr_t = torch.tensor(y_d_tr, dtype=torch.float32).to(device)
X_va_t = torch.tensor(X_d_va, dtype=torch.float32).to(device)
y_va_t = torch.tensor(y_d_va, dtype=torch.float32).to(device)

loader = DataLoader(TensorDataset(X_tr_t, y_tr_t), batch_size=batch_size, shuffle=True)

best_val_auc = 0
training_history = []

for epoch in range(epochs):
    model.train()
    total_loss = 0
    for xb, yb in loader:
        optimizer.zero_grad()
        logits, _ = model(xb)
        loss = criterion(logits, yb)
        loss.backward()
        optimizer.step()
        total_loss += loss.item()
    
    avg_loss = total_loss / len(loader)
    training_history.append(avg_loss)
    
    # Quick validation
    model.eval()
    with torch.no_grad():
        val_logits, _ = model(X_va_t)
        val_probs = torch.sigmoid(val_logits).cpu().numpy()
        val_auc = roc_auc_score(y_d_va, val_probs)
    
    if (epoch + 1) % 5 == 0 or epoch == epochs-1:
        print(f"Epoch {epoch+1:2d}/{epochs} | Loss: {avg_loss:.4f} | Val AUC: {val_auc:.4f}")
    
    if val_auc > best_val_auc:
        best_val_auc = val_auc

# Plot training
plt.figure(figsize=(8, 5))
plt.plot(training_history, label='Training Loss', color='#2ca02c', linewidth=2)
plt.xlabel('Epoch')
plt.ylabel('Loss')
plt.title('Proposed Model Training Progress')
plt.legend()
plt.grid(True, alpha=0.3)
