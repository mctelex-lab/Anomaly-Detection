def train_benchmark_xgb(X_train, y_train, X_val, y_val, anomaly_ratio, device):
    scale_pos_weight = (1 - anomaly_ratio) / (anomaly_ratio + 1e-6)
    
    # Ensure both classes are present in validation set
    unique_train = np.unique(y_train)
    unique_val = np.unique(y_val)
    
    if len(unique_train) < 2:
        print(f"  [WARN] Training set has only class {unique_train[0]}, adjusting...")
        # Add synthetic sample of minority class if needed
        pass
    
    tree_method = 'hist'  # Use hist for CPU compatibility
    if device.type == 'cuda' and torch.cuda.is_available():
        try:
            tree_method = 'gpu_hist'
        except:
            tree_method = 'hist'
    
    xgb_model = xgb.XGBClassifier(
        objective='binary:logistic',
        eval_metric='logloss',
        max_depth=8,
        n_estimators=300,
        learning_rate=0.03,
        subsample=0.8,
        colsample_bytree=0.8,
        scale_pos_weight=scale_pos_weight,
        tree_method=tree_method,
        random_state=42,
        use_label_encoder=False
    )
    
    # Fit with early stopping only if validation has both classes
    eval_set = [(X_val, y_val)]
    
    xgb_model.fit(
        X_train, y_train, 
        eval_set=eval_set,
        verbose=False
    )
    
    return xgb_model

# Train benchmark on both datasets
