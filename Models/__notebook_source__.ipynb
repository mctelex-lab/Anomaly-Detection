def calculate_auc_pr(y_true, y_scores):
    """Robust AUC-PR calculation that handles non-monotonic arrays"""
    try:
        precision, recall, _ = precision_recall_curve(y_true, y_scores)
        unique_indices = np.unique(recall, return_index=True)[1]
        recall_unique = recall[unique_indices]
        precision_unique = precision[unique_indices]
        sort_idx = np.argsort(recall_unique)
        recall_sorted = recall_unique[sort_idx]
        precision_sorted = precision_unique[sort_idx]
        auc_pr = integrate.trapezoid(precision_sorted, recall_sorted)
        return auc_pr
    except Exception as e:
        print(f"[WARN] AUC-PR calculation failed: {e}, using fallback")
        precision, recall, _ = precision_recall_curve(y_true, y_scores)
        sort_idx = np.argsort(recall)
        recall_sorted = recall[sort_idx]
        precision_sorted = precision[sort_idx]
        return auc(recall_sorted, precision_sorted)

def find_optimal_threshold(y_true, y_probs):
    """Find threshold that maximizes F1-score"""
    precision, recall, thresholds = precision_recall_curve(y_true, y_probs)
    with np.errstate(divide='ignore', invalid='ignore'):
        f1_scores = 2 * (precision * recall) / (precision + recall + 1e-8)
    f1_scores = np.nan_to_num(f1_scores, nan=0.0)
    optimal_idx = np.argmax(f1_scores)
    return thresholds[optimal_idx] if optimal_idx < len(thresholds) else 0.5

