def load_and_preprocess_data(file_path, dataset_name):
    print(f"\n[INFO] Loading {dataset_name}...")
    
    df = None
    parsing_errors = []
    
    try:
        df = pd.read_csv(file_path, low_memory=False, on_bad_lines='skip', engine='python')
    except Exception as e:
        parsing_errors.append(f"Strategy 1 failed: {e}")
    
    if df is None:
        try:
            with open(file_path, 'r', encoding='utf-8', errors='ignore') as f:
                first_lines = [f.readline() for _ in range(5)]
            delimiters = [',', ';', '\t', '|']
            counts = {d: sum(line.count(d) for line in first_lines) for d in delimiters}
            detected_delim = max(counts, key=counts.get)
            df = pd.read_csv(file_path, sep=detected_delim, engine='python',
                           on_bad_lines='warn', low_memory=False)
        except Exception as e:
            parsing_errors.append(f"Strategy 2 failed: {e}")
    
    if df is None:
        try:
            df = pd.read_csv(file_path, engine='python', on_bad_lines='skip')
        except Exception as e:
            parsing_errors.append(f"Strategy 3 failed: {e}")
    
    if df is None:
        raise ValueError(f"All parsing strategies failed. Errors: {parsing_errors}")
    
    print(f"[INFO] Raw data shape: {df.shape}")
    
    df.columns = df.columns.str.strip().str.replace(' ', '_').str.replace('/', '_').str.lower()
    
    meta_features = [
        'flow_duration', 'tot_fwd_pkts', 'tot_bwd_pkts', 'totlen_fwd_pkts', 
        'totlen_bwd_pkts', 'fwd_pkt_len_max', 'fwd_pkt_len_min', 'fwd_pkt_len_mean', 
        'fwd_pkt_len_std', 'bwd_pkt_len_max', 'bwd_pkt_len_min', 'bwd_pkt_len_mean', 
        'bwd_pkt_len_std', 'flow_iat_mean', 'flow_iat_std', 'flow_iat_max', 
        'flow_iat_min', 'fwd_psh_flags', 'bwd_psh_flags', 'fwd_urg_flags', 
        'bwd_urg_flags', 'fwd_header_len', 'bwd_header_len', 'fwd_pkts_s', 
        'bwd_pkts_s', 'min_pkt_len', 'max_pkt_len', 'pkt_len_mean', 
        'pkt_len_std', 'fin_flag_count', 'syn_flag_count', 'rst_flag_count', 
        'psh_flag_count', 'ack_flag_count', 'urg_flag_count', 'down_up_ratio', 
        'avg_pkt_size', 'avg_fwd_segment_size', 'avg_bwd_segment_size', 
        'subflow_fwd_pkts', 'subflow_bwd_pkts', 'init_win_bytes_forward', 
        'init_win_bytes_backward'
    ]
    
    available_features = [col for col in meta_features if col in df.columns]
    
    label_col = None
    for possible_label in ['label', 'Label', 'class', 'attack', 'category']:
        if possible_label.lower() in df.columns.str.lower():
            label_col = [c for c in df.columns if c.lower() == possible_label.lower()][0]
            break
    
    if label_col is None:
        if df.iloc[:, -1].dtype == 'object' or df.iloc[:, -1].nunique() < 50:
            label_col = df.columns[-1]
        else:
            raise ValueError("Could not identify label column")
    
    df_clean = df[available_features + [label_col]].copy()
    df_clean[label_col] = df_clean[label_col].astype(str)
    
    for col in available_features:
        if col in df_clean.columns:
            df_clean[col] = pd.to_numeric(df_clean[col], errors='coerce')
    
    df_clean.replace([np.inf, -np.inf], np.nan, inplace=True)
    df_clean.fillna(0, inplace=True)
    
    le = LabelEncoder()
    df_clean['label_encoded'] = le.fit_transform(df_clean[label_col])
    
    benign_patterns = ['benign', 'normal', 'legitimate', '0', 'clean']
    is_benign = df_clean[label_col].str.lower().str.contains('|'.join(benign_patterns), na=False)
    df_clean['is_anomaly'] = (~is_benign).astype(int)
    
    X = df_clean[available_features].values
    y = df_clean['is_anomaly'].values
    
    anomaly_ratio = y.mean()
    print(f"[INFO] {dataset_name} processed. Shape: {X.shape}, Anomaly ratio: {anomaly_ratio:.3f}")
    print(f"[INFO] Features used: {len(available_features)}")
    return X, y, le, available_features, anomaly_ratio

