def plot_confusion_detailed(cm, title, filename, class_names=['Benign', 'Anomaly']):
    """Enhanced confusion matrix with percentages and annotations"""
    fig, ax = plt.subplots(figsize=(8, 7))
    
    # Calculate percentages
    cm_normalized = cm.astype('float') / cm.sum(axis=1)[:, np.newaxis] * 100
    
    # Plot with annotations
    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', cbar_kws={'label': 'Count'},
                xticklabels=class_names, yticklabels=class_names, ax=ax,
                annot_kws={'size': 12, 'weight': 'bold'})
    
    # Add percentage annotations
    for i in range(cm.shape[0]):
        for j in range(cm.shape[1]):
            pct = cm_normalized[i, j]
            ax.text(j + 0.5, i + 0.7, f'({pct:.1f}%)',
                   ha='center', va='center', fontsize=10, color='darkred', fontweight='bold')
    
    ax.set_xlabel('Predicted Label', fontweight='bold', fontsize=13)
    ax.set_ylabel('Actual Label', fontweight='bold', fontsize=13)
    ax.set_title(title, fontweight='bold', fontsize=15, pad=20)
    
    # Add performance metrics as text
    tn, fp, fn, tp = cm.ravel()
    accuracy = (tp + tn) / cm.sum()
    precision = tp / (tp + fp) if (tp + fp) > 0 else 0
    recall = tp / (tp + fn) if (tp + fn) > 0 else 0
    f1 = 2 * precision * recall / (precision + recall) if (precision + recall) > 0 else 0
    
    metrics_text = f"Accuracy: {accuracy:.3f} | Precision: {precision:.3f} | Recall: {recall:.3f} | F1: {f1:.3f}"
    ax.text(1.02, 0.5, metrics_text, transform=ax.transAxes, fontsize=10, 
            bbox=dict(boxstyle='round', facecolor='wheat', alpha=0.5), va='center')
    
    plt.tight_layout()
    plt.savefig(filename, dpi=300, bbox_inches='tight')
    plt.show()
    
    return {'TN': tn, 'FP': fp, 'FN': fn, 'TP': tp, 'Accuracy': accuracy, 
            'Precision': precision, 'Recall': recall, 'F1': f1}

