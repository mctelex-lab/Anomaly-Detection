# 3. EVALUATION AND METRICS (Objectives 1, 2, 3)
# =============================================================================
def evaluate_model(model, X_test, y_test, device):
    model.eval()
    X_t = torch.tensor(X_test, dtype=torch.float32).to(device)
    
    # Latency measurement (multiple runs for stability)
    latencies = []
    for _ in range(3):  # Average over 3 runs
        start = time.perf_counter()
        with torch.no_grad():
            logits, importances = model(X_t)
        latency_total = time.perf_counter() - start
        latencies.append((latency_total / len(X_test)) * 1000)  # ms per flow
    
    latency_per_flow = np.mean(latencies)
    
    probs = torch.sigmoid(logits).cpu().numpy()
    preds = (probs > 0.5).astype(int)
    
    acc = accuracy_score(y_test, preds)
    prec = precision_score(y_test, preds, zero_division=0)
    rec = recall_score(y_test, preds, zero_division=0)
    f1 = f1_score(y_test, preds, zero_division=0)
    auc = roc_auc_score(y_test, probs)
    
    metrics = {'Accuracy': acc, 'Precision': prec, 'Recall': rec, 
               'F1-Score': f1, 'AUC': auc, 'Latency_ms': latency_per_flow}
    return metrics, preds, probs, importances

print("\n[EVALUATION] Testing Proposed Model")
m_dark, p_dark, prob_dark, imp_dark = evaluate_model(model, X_d_te, y_d_te, device)
