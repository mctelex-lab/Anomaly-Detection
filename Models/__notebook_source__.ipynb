print("\n[BENCHMARK] Training XGBoost + SHAP with Class Weighting")

def train_benchmark_xgb_safe(X_train, y_train, X_val, y_val, anomaly_ratio, device):
    """
    Safe XGBoost training that handles validation set with single class.
    CRITICAL FIX: Only pass eval_set if validation has BOTH classes [0, 1].
    """
    scale_pos_weight = (1 - anomaly_ratio) / (anomaly_ratio + 1e-6)
    
    # Check if validation set has both classes for proper evaluation
    unique_val = np.unique(y_val)
    has_both_classes = len(unique_val) == 2 and set(unique_val) == {0, 1}
    
    xgb_model = xgb.XGBClassifier(
        objective='binary:logistic',
        eval_metric='logloss',
        max_depth=8,
        n_estimators=300,
        learning_rate=0.03,
        subsample=0.8,
        colsample_bytree=0.8,
        scale_pos_weight=scale_pos_weight,
        tree_method='hist',  # CPU-compatible
        random_state=42,
        use_label_encoder=False
    )
    
    if has_both_classes:
        print(f"  Validation has both classes [0,1], using early stopping with eval_set")
        xgb_model.fit(
            X_train, y_train,
            eval_set=[(X_val, y_val)],
            verbose=False
        )
    else:
        print(f"  Validation has single class {unique_val}, training WITHOUT eval_set to avoid XGBoost error")
        # Train without eval_set when validation lacks both classes
        xgb_model.fit(X_train, y_train, verbose=False)
    
    return xgb_model

