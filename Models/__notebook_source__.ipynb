# Create a simple inference script for Streamlit
inference_script = '''
import torch
import joblib
import json
import numpy as np

class FastAttributionExplainer(torch.nn.Module):
    def __init__(self, input_dim):
        super().__init__()
        self.net = torch.nn.Sequential(
            torch.nn.Linear(input_dim, 128),
            torch.nn.BatchNorm1d(128),
            torch.nn.ReLU(),
            torch.nn.Dropout(0.2),
            torch.nn.Linear(128, 64),
            torch.nn.BatchNorm1d(64),
            torch.nn.ReLU(),
            torch.nn.Linear(64, input_dim)
        )
    def forward(self, x):
        return self.net(x)

class RelationalModelingLayer(torch.nn.Module):
    def __init__(self, input_dim, output_dim):
        super().__init__()
        self.relation_net = torch.nn.Sequential(
            torch.nn.Linear(input_dim, output_dim * 4),
            torch.nn.BatchNorm1d(output_dim * 4),
            torch.nn.ReLU(),
            torch.nn.Dropout(0.3),
            torch.nn.Linear(output_dim * 4, output_dim * 2),
            torch.nn.BatchNorm1d(output_dim * 2),
            torch.nn.ReLU(),
            torch.nn.Linear(output_dim * 2, output_dim)
        )
        self.residual = torch.nn.Linear(input_dim, output_dim) if input_dim != output_dim else torch.nn.Identity()
        
    def forward(self, x):
        relational = self.relation_net(x)
        residual = self.residual(x)
        return torch.nn.functional.relu(relational + residual)

class ProposedAnomalyDetector(torch.nn.Module):
    def __init__(self, tabular_dim, relational_dim=64):
        super().__init__()
        self.tabular_net = torch.nn.Sequential(
            torch.nn.Linear(tabular_dim, 128),
            torch.nn.BatchNorm1d(128),
            torch.nn.ReLU(),
            torch.nn.Dropout(0.3),
            torch.nn.Linear(128, 64),
            torch.nn.BatchNorm1d(64),
            torch.nn.ReLU()
        )
        self.relational_layer = RelationalModelingLayer(tabular_dim, relational_dim)
        self.classifier = torch.nn.Sequential(
            torch.nn.Linear(64 + relational_dim, 64),
            torch.nn.BatchNorm1d(64),
            torch.nn.ReLU(),
            torch.nn.Dropout(0.3),
            torch.nn.Linear(64, 32),
            torch.nn.ReLU(),
            torch.nn.Linear(32, 1)
        )
        self.explainer = FastAttributionExplainer(tabular_dim)
        
    def forward(self, x):
        tabular_feat = self.tabular_net(x)
        relational_feat = self.relational_layer(x)
        combined = torch.cat([tabular_feat, relational_feat], dim=1)
        logits = self.classifier(combined).squeeze(-1)
        importances = self.explainer(x)
        return logits, importances

def load_model(model_path, input_dim):
    model = ProposedAnomalyDetector(tabular_dim=input_dim)
    state_dict = torch.load(model_path, map_location='cpu')
    model.load_state_dict(state_dict)
    model.eval()
    return model

def predict(model, scaler, features, threshold=0.5):
    scaled_features = scaler.transform(features.reshape(1, -1))
